@startuml
hide circle
skinparam linetype ortho

entity "images" as images {
  * id : BIGINT <<PK>>
  --
  * data : BLOB
  * mime_type : VARCHAR(100)
}

entity "users" as users {
  * id : BIGINT <<PK>>
  --
  * name : VARCHAR(255)
  username : VARCHAR(64) <<UQ>>
  * email : VARCHAR(255) <<UQ>>
  password_hash : VARCHAR(72)
  * preferred_locale : VARCHAR(8)
  profile_image_id : BIGINT <<FK>>
  profile_description : TEXT
  * created_at : TIMESTAMP
}

entity "user_roles" as user_roles {
  * user_id : BIGINT <<PK, FK>>
  * role : VARCHAR(32) <<PK>>
}

entity "user_claim_tokens" as user_claim_tokens {
  * id : BIGINT <<PK>>
  --
  * user_id : BIGINT <<FK>>
  * token_hash : CHAR(64) <<UQ>>
  * expires_at : TIMESTAMP
  consumed_at : TIMESTAMP
  * created_at : TIMESTAMP
}

entity "user_password_reset_tokens" as user_pwd_reset {
  * id : BIGINT <<PK>>
  --
  * user_id : BIGINT <<FK>>
  * token_hash : CHAR(64) <<UQ>>
  * expires_at : TIMESTAMP
  consumed_at : TIMESTAMP
  * created_at : TIMESTAMP
}

entity "restaurants" as restaurants {
  * id : BIGINT <<PK>>
  --
  * name : VARCHAR(255)
  * slug : VARCHAR(255) <<UQ>>
  cuisine : VARCHAR(100)
  neighborhood : VARCHAR(100)
  address : VARCHAR(500)
  description : TEXT
  image_url : VARCHAR(1000)
  price_range : VARCHAR(10)
  phone : VARCHAR(50)
  email : VARCHAR(255)
  tags : VARCHAR(500)
  menu : TEXT
  is_open : BOOLEAN
  image_id : BIGINT <<FK>>
  owner_id : BIGINT <<FK>>
  * status : VARCHAR(16)
  rejection_reason : TEXT
  submitted_at : TIMESTAMP
  reviewed_at : TIMESTAMP
  accepts_reservations : BOOLEAN
  reservation_disabled_mode : VARCHAR(32)
  reservation_external_link : VARCHAR(1000)
  reservation_confirmation_mode : VARCHAR(16)
  reservation_slot_duration_minutes : SMALLINT
}

entity "restaurant_hours" as restaurant_hours {
  * id : BIGINT <<PK>>
  --
  * restaurant_id : BIGINT <<FK>>
  * day_of_week : SMALLINT
  * shift : SMALLINT
  * open_time : TIME
  * close_time : TIME
}

entity "reviews" as reviews {
  * id : BIGINT <<PK>>
  --
  * restaurant_id : BIGINT <<FK>>
  * user_id : BIGINT <<FK>>
  * rating : NUMERIC(2,1)
  comment : TEXT
  created_at : TIMESTAMP
  reservation_id : BIGINT <<FK>> <<UQ>>
}

entity "restaurant_tables" as restaurant_tables {
  * id : BIGINT <<PK>>
  --
  * restaurant_id : BIGINT <<FK>>
  * table_number : INTEGER
  * capacity : SMALLINT
  * created_at : TIMESTAMP
}

entity "reservations" as reservations {
  * id : BIGINT <<PK>>
  --
  * restaurant_id : BIGINT <<FK>>
  * user_id : BIGINT <<FK>>
  * table_id : BIGINT <<FK>>
  * reservation_date : DATE
  * slot_start : TIME
  * slot_end : TIME
  * party_size : SMALLINT
  comment : TEXT
  * status : VARCHAR(16)
  * no_show : BOOLEAN
  * cancelled_by_user : BOOLEAN
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
}

entity "reservation_notifications" as reservation_notifications {
  * id : BIGINT <<PK>>
  --
  * reservation_id : BIGINT <<FK>>
  * notification_type : VARCHAR(32)
  * sent_at : TIMESTAMP
}

note as BusinessNotes
  **Notas funcionales de reservas:**
  - PENDING y CONFIRMED bloquean el slot de la mesa.
  - CANCELLED y COMPLETED no bloquean disponibilidad.
  - no_show es un flag, no un estado principal.
  - Una reserva se completa automáticamente cuando termina su franja horaria y estaba CONFIRMED.
  - Un restaurante no puede cambiar su layout si tiene reservas PENDING o CONFIRMED.
  - Los slots se derivan de restaurant_hours + reservation_slot_duration_minutes.
  - La review solo puede existir sobre una reserva completada.
end note

users }|--|| images : "profile_image_id"
user_roles }|--|| users : "user_id"
user_claim_tokens }|--|| users : "user_id"
user_pwd_reset }|--|| users : "user_id"
restaurants }|--|| images : "image_id"
restaurants }|--|| users : "owner_id"
restaurant_hours }|--|| restaurants : "restaurant_id"
reviews }|--|| restaurants : "restaurant_id"
reviews }|--|| users : "user_id"
restaurants }|--|| restaurant_tables : "restaurant_id"
restaurants }|--|| reservations : "restaurant_id"
users }|--|| reservations : "user_id"
restaurant_tables }|--|| reservations : "table_id"
reservations }|--|| reservation_notifications : "reservation_id"
reviews |o--|| reservations : "reservation_id"

@enduml
